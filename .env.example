# Variáveis de ambiente para o pipeline de ingestão — Lojas Emanuella
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env  (Windows)

# Token de API da DataMission (obrigatório para execução)
# Substitua pelo token fornecido no desafio:
API_TOKEN=seu-token-aqui

# Project ID (opcional — já configurado no script)
# PROJECT_ID=1751329c-152c-42dd-822d-ad62f1328c01
